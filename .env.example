# ====== LINE Messaging API ======
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_long_lived_access_token
# 管理員 LINE userId（可在 LINE Developers 後台 / 加機器人為好友後取得）
LINE_ADMIN_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====== n8n Webhook ======
# 例：https://n8n.example.com/webhook/line-agent
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/line-agent
# 共用密鑰，n8n 端用 Header 驗證來源
N8N_SHARED_SECRET=please_change_me

# ====== Supabase ======
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# 直接連 Postgres（給 n8n / 後台工具使用）
DATABASE_URL=postgres://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# ====== AI Provider（任一即可，n8n 端會擇一呼叫）======
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ====== Server ======
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
